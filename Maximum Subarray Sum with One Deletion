class Solution {
    public int maximumSum(int[] arr) {
       int pnd = arr[0];
       int pwd = 0;
       int max = arr[0];
       for(int i =1; i < arr.length;i++){
        pwd=Math.max(pnd,pwd +arr[i]);
        pnd = Math.max(pnd + arr[i],arr[i]);
        max= Math.max(max,Math.max(pnd,pwd));
       }
       System.gc();
       return max; 
    }
}
